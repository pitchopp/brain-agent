# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET=generate-a-random-string
# CSV list of allowed Telegram user ids (fail-closed if empty)
ALLOWED_TELEGRAM_USER_IDS=123456789
# Chat id used to notify the admin (e.g. git conflicts). Usually your own user id.
TELEGRAM_ADMIN_CHAT_ID=123456789

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Git / brain repo
BRAIN_REPO_URL=git@github.com:pitchopp/brain.git
BRAIN_REPO_BRANCH=main
BRAIN_LOCAL_PATH=/data/brain
GIT_USER_NAME=brain-agent
GIT_USER_EMAIL=brain-agent@local
# Multiline PEM private key with write access to the brain repo.
# In Dokploy, paste the full key (including BEGIN/END lines) in the env var.
GIT_SSH_PRIVATE_KEY=

# Runtime
BRAIN_PULL_INTERVAL_SECONDS=300
MAX_AGENT_TURNS=20
AGENT_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO
